{
  "name": "@gks101/luminajs",
  "version": "1.1.5",
  "description": "A modular, lightweight JavaScript utility library for browser-based image processing using the HTML5 Canvas API.",
  "type": "module",
  "types": "./dist/types/index.d.ts",
  "main": "./dist/lumina.umd.js",
  "module": "./dist/lumina.esm.js",
  "browser": "./dist/lumina.umd.js",
  "unpkg": "./dist/lumina.min.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/lumina.umd.js"
    },
    "./filters": "./src/filters/index.js",
    "./core": "./src/core/index.js"
  },
  "scripts": {
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc",
    "dev": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.0",
    "rollup": "^4.0.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "image-processing",
    "canvas",
    "filter",
    "grayscale",
    "sepia",
    "browser",
    "lightweight"
  ],
  "author": "LuminaJS and Gaurav",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  }
}